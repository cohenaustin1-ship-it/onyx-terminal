# ─── Tick Ingestion Service Config ────────────────────────────────────────────

# DuckDB file path (use absolute in production, relative for dev)
DB_PATH=./data/onyx_ticks.duckdb

# Service port
PORT=8001

# JWT secret — must match the executor + agent so tokens are interchangeable.
# REQUIRED in production. Dev generates an ephemeral one if unset.
JWT_SECRET=

# Legacy shared bearer — accepted alongside JWTs during migration.
# Set to empty to force JWT-only.
LEGACY_AUTH_TOKEN=dev_local_token_change_me

# Sentry (optional) — sign up at https://sentry.io for free tier
SENTRY_DSN=

# Rate limits (per IP per minute)
RATE_LIMIT_PUBLIC=120/minute
RATE_LIMIT_READ=60/minute

# Comma-separated symbols to subscribe to on Coinbase
COINBASE_SYMBOLS=BTC-USD,ETH-USD,SOL-USD

# Polygon API key (optional — for equities backfill)
POLYGON_API_KEY=

# Hyperliquid endpoint (optional — disabled by default since needs domain work)
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_ENABLED=false

# Janitor — drop ticks older than this many days
RETENTION_DAYS=30

# Producer batch size — write to DB after this many ticks accumulate
BATCH_SIZE=50

# Producer batch flush interval — write at least this often even if batch not full
BATCH_FLUSH_SECONDS=2
