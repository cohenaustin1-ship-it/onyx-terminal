# ─── Onyx Agent (ZeroClaw-style) Service Config ────────────────────────────

PORT=7777

# JWT secret — REQUIRED in prod. Must be SAME value as JWT_SECRET in the
# executor so tokens issued by either service work on both.
JWT_SECRET=

# Legacy shared bearer — kept for backwards-compat during migration
LEGACY_AUTH_TOKEN=dev_local_token_change_me

# Sentry (optional)
SENTRY_DSN=

# Rate limits
RATE_LIMIT_PUBLIC=120
RATE_LIMIT_READ=60
RATE_LIMIT_WRITE=20
RATE_LIMIT_LLM=15

# LLM provider chain (tries in order, falls through on error)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Exa — gives the agent live web-search + scrape tools (exa_search, exa_contents)
# Sign up at exa.ai. The SPA can route through here to avoid CORS in production.
EXA_API_KEY=

# Default model + fallback chain
LLM_PRIMARY=anthropic
LLM_FALLBACK=openai
LLM_LOCAL=ollama

# Memory (file-backed JSON for now; swap to Postgres for prod)
MEMORY_PATH=./data/agent_memory.json

# Notifications — Telegram (easiest channel to wire)
# Get a bot token from @BotFather, then have your user message the bot
# once and call POST /telegram/register with their chat_id
TELEGRAM_BOT_TOKEN=

# Webhook URL the SPA's executor sends events to (for "signal_fired" skill)
EXECUTOR_WS_URL=ws://executor:8002/ws/events
EXECUTOR_AUTH_TOKEN=dev_local_token_change_me
TICK_API_URL=http://tick-ingestion:8001
TICK_API_TOKEN=dev_local_token_change_me
EXECUTOR_API_URL=http://executor:8002
