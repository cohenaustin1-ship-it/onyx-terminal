# ─── Strategy Executor Service Config ────────────────────────────────────────

# Service port
PORT=8002

# JWT secret — REQUIRED in production. In dev a random one is generated on
# boot. Set this to a long random string and keep it identical across
# restarts so issued tokens stay valid.
JWT_SECRET=

# Legacy shared bearer — accepted alongside JWT during migration. Set this
# to the same value as VITE_BACKEND_AUTH_TOKEN in the SPA. Leave empty to
# force JWT-only.
LEGACY_AUTH_TOKEN=dev_local_token_change_me

# Sentry (optional) — sign up at https://sentry.io for free tier, copy
# the DSN here. Captures unhandled errors + traces 10% of requests.
SENTRY_DSN=

# Rate limits (per IP, per minute)
RATE_LIMIT_PUBLIC=120
RATE_LIMIT_READ=60
RATE_LIMIT_WRITE=20

# Tick API to pull market data from
TICK_API_URL=http://tick-ingestion:8001
TICK_API_TOKEN=dev_local_token_change_me

# Postgres (use docker-compose default for local dev)
DATABASE_URL=postgres://onyx:onyx@postgres:5432/onyx_executor

# Active broker adapter — one of: paper | alpaca | bitget
BROKER_ADAPTER=paper

# Alpaca paper trading (only used if BROKER_ADAPTER=alpaca)
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Bitget (only used if BROKER_ADAPTER=bitget)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Risk caps (global, per user)
MAX_TRADES_PER_DAY=10
MAX_TRADE_SIZE_USD=500
MAX_NEW_POSITIONS_PER_HOUR=3

# Path for the audit CSV (mounted as a volume in production)
TRADES_CSV_PATH=./data/trades.csv
