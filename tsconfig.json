{
  "compilerOptions": {
    /* Phase 3p.34 — gradual TypeScript adoption via JSDoc.
     *
     * Strategy: use TypeScript only as a static analyzer (noEmit), with
     * checkJs: false so it only inspects files that opt in via an
     * explicit `// @ts-check` pragma. This way we can add type checking
     * one module at a time without disrupting the rest of the codebase.
     *
     * To check the whole project: `npx tsc --noEmit`
     * To check a single file: add `// @ts-check` and run the same.
     */

    /* Output */
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,

    /* Module resolution */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    /* JSX — must NOT be 'preserve' or vite/rolldown breaks JSX import
     * analysis. 'react-jsx' is the runtime-import mode used by Vite. */
    "jsx": "react-jsx",

    /* Strictness — relatively strict but not maximal. We can tighten
     * later as more files opt in. */
    "strict": true,
    "noImplicitAny": false,        /* JSDoc-checked files often
                                      have implicit any until we annotate */
    "strictNullChecks": true,      /* This is the big win — catches
                                      the change24h-style bugs. */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* React types */
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.d.ts",
    "JPMOnyxTerminal.jsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "services",
    "sequencer",
    "e2e"
  ]
}
